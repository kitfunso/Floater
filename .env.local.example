# Floater - Working Capital Optimiser env vars
# Copy to .env.local and fill in. .env.local is gitignored.

# Specter (vendor distress signals)
SPECTER_API_KEY=
SPECTER_BASE_URL=https://api.tryspecter.com

# Cursor SDK (sub-agent fan-out, needed at Step 7a)
CURSOR_API_KEY=

# OpenAI (LLM narration; cached fixtures under DEMO_REPLAY=1)
OPENAI_API_KEY=

# Demo replay: 1 = use cached fixtures, 0 = live API calls.
# Set to 1 in production deploys to keep the demo critical path off the live network.
DEMO_REPLAY=1
